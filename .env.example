# Copy this file to .env.local and fill in values.
# Marketing pages (/, /features, /pricing) work without these.
# Login and dashboard require the "Required" section.

# ── Required for auth & dashboard ─────────────────────────────────────────────

# PostgreSQL connection string (Supabase → Project Settings → Database)
DATABASE_URL=

# Random secret — run: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth URLs (defaults to http://localhost:3000 if unset) ──────────────────

BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional integrations ─────────────────────────────────────────────────────

# Google OAuth (login page)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Magic link emails (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Marketme <onboarding@resend.dev>

# AI content generation
OPENAI_API_KEY=

# Trigger.dev background jobs (image gen, scheduled publishing)
TRIGGER_SECRET_KEY=

# Stock images (studio)
PEXELS_API_KEY=

# Billing
STRIPE_SECRET_KEY=

# Better Auth dashboard plugin
BETTER_AUTH_API_KEY=

# External AI service (defaults to http://localhost:8000)
MARKETME_AI_API_URL=

# Auto-publish scheduled posts to Instagram (requires Instagram connection)
ENABLE_AUTO_PUBLISH=false

# Supabase storage bucket for generated content
NEXT_PUBLIC_SUPABASE_BUCKET=generated-content
